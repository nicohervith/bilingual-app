          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_art_conversation",
            "title": "Conversación sobre Arte",
            "config": {
              "scenario": "Discussing art and creativity with an artist friend",
              "dialogues": [
                {
                  "character": "artist",
