{
  "lessons": {
    "A1_sports": {
      "id": "A1_sports",
      "title": "Sports Activities",
      "xpReward": 75,
      "metadata": {
        "level": "A1",
        "module": "vocabulary",
        "unit": "unitA1_sports",
        "xpReward": 75,
        "estimatedDuration": 25,
        "tags": ["sports", "present_continuous", "action_verbs"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_soccer",
            "word": "Playing soccer",
            "translation": "Jugando fútbol",
            "examples": ["I am playing soccer with my friends"],
            "media": {
              "image": "https://example.com/soccer.jpg"
            }
          },
          {
            "id": "voc_swimming",
            "word": "Swimming",
            "translation": "Nadando",
            "examples": ["She is swimming in the pool"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_sports_memory",
            "title": "Sports Memory Match",
            "config": {
              "pairs": [
                {
                  "front": "Basketball",
                  "back": "Baloncesto"
                },
                {
                  "front": "Tennis",
                  "back": "Tenis"
                },
                {
                  "front": "Running",
                  "back": "Corriendo"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex2_sports_actions",
            "title": "Build Sports Sentences",
            "config": {
              "wordBank": [
                "I",
                "am",
                "playing",
                "watching",
                "soccer",
                "tennis",
                "on",
                "TV"
              ],
              "correctAnswers": [
                "I am playing soccer",
                "I am playing tennis",
                "I am watching soccer on TV"
              ],
              "requiredWords": ["am", "playing"],
              "timeLimit": 60
            }
          }
        ]
      }
    },
    "A1_past_experiences_2": {
      "id": "A1_past_experiences_2",
      "title": "Past Experiences",
      "xpReward": 80,
      "metadata": {
        "level": "A1",
        "module": "grammar",
        "unit": "unitA1_past",
        "xpReward": 80,
        "estimatedDuration": 30,
        "tags": ["past_simple", "irregular_verbs", "experiences"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_went",
            "word": "Went",
            "translation": "Fui",
            "examples": ["I went to the beach last summer"]
          },
          {
            "id": "voc_ate",
            "word": "Ate",
            "translation": "Comí",
            "examples": ["We ate pizza yesterday"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_irregular_verbs",
            "title": "Match Irregular Verbs",
            "config": {
              "pairs": [
                {
                  "from": "Go → Went",
                  "to": "Ir → Fui"
                },
                {
                  "from": "Eat → Ate",
                  "to": "Comer → Comí"
                },
                {
                  "from": "See → Saw",
                  "to": "Ver → Vi"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_past_conjugation",
            "title": "Conjugate in Past Simple",
            "config": {
              "verb": "to go",
              "pronouns": ["I", "You", "He", "We"],
              "correct": {
                "I": "went",
                "You": "went",
                "He": "went",
                "We": "went"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          }
        ]
      }
    },
    "A1_goals": {
      "id": "A1_goals",
      "title": "Goals and Aspirations",
      "xpReward": 85,
      "metadata": {
        "level": "A1",
        "module": "grammar",
        "unit": "unitA1_goals",
        "xpReward": 85,
        "estimatedDuration": 35,
        "tags": ["future", "goals", "aspirations", "will", "going_to"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_travel",
            "word": "Will travel",
            "translation": "Viajaré",
            "examples": ["I will travel to Japan next year"]
          },
          {
            "id": "voc_study",
            "word": "Going to study",
            "translation": "Voy a estudiar",
            "examples": ["I am going to study medicine"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_future_forms",
            "title": "Match Future Expressions",
            "config": {
              "pairs": [
                {
                  "from": "I will",
                  "to": "Yo haré (decisión)"
                },
                {
                  "from": "I am going to",
                  "to": "Yo voy a (plan)"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex2_goals_sentences",
            "title": "Build Future Goals",
            "config": {
              "wordBank": [
                "I",
                "will",
                "am",
                "going",
                "to",
                "study",
                "travel",
                "work",
                "next",
                "year"
              ],
              "correctAnswers": [
                "I will study next year",
                "I am going to travel next year",
                "I will work next year"
              ],
              "requiredWords": ["I"],
              "timeLimit": 90
            }
          }
        ]
      }
    }
  }
}
