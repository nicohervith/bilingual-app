        "tags": [
          "present_continuous",
          "perception_verbs",
          "music",
          "concerts",
          "genres"
        ]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_hearing",
            "word": "Hearing",
            "translation": "Escuchando",
            "examples": ["I am hearing beautiful music"],
            "tags": ["present_continuous", "perception"]
          },
          {
            "id": "voc_listening",
            "word": "Listening",
            "translation": "Escuchando",
            "examples": ["We are listening to a concert"],
            "tags": ["present_continuous", "music"]
          },
          {
            "id": "voc_concert",
            "word": "Concert",
            "translation": "Concierto",
            "examples": ["The concert starts at 8 PM"]
          },
          {
            "id": "voc_genre",
            "word": "Genre",
            "translation": "Género",
            "examples": ["My favorite music genre is jazz"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_music_vocabulary",
            "title": "Vocabulario Musical",
            "config": {
              "pairs": [
                {
                  "from": "Concert",
                  "to": "Concierto"
                },
                {
                  "from": "Genre",
                  "back": "Género"
                },
                {
                  "from": "Melody",
                  "to": "Melodía"
                },
                {
                  "from": "Rhythm",
                  "to": "Ritmo"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_perception_verbs",
            "title": "Verbos de Percepción en Presente Continuo",
            "config": {
              "verb": "to hear",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Present Continuous"],
              "correct": {
                "I": "am hearing",
                "You": "are hearing",
                "He": "is hearing",
                "We": "are hearing",
                "They": "are hearing"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_music_experiences",
            "title": "Describe Experiencias Musicales",
            "config": {
              "wordBank": [
                "I",
                "am",
                "listening",
                "hearing",
                "watching",
                "a",
                "concert",
                "music",
                "song",
                "right",
                "now",
                "this",
                "band",
                "plays",
                "rock",
                "jazz",
                "pop"
              ],
              "correctAnswers": [
                "I am listening to a concert",
                "We are hearing beautiful music",
                "They are watching the band play"
              ],
              "requiredWords": ["am", "are", "is"],
              "timeLimit": 120
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_concert_conversation",
            "title": "Conversación sobre Conciertos",
            "config": {
              "scenario": "Talking about music concerts with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "What are you listening to right now?",
                  "options": [
                    "I am listening to a jazz concert",
                    "I'm hearing some new music"
                  ]
                },
                {
                  "character": "user",
                  "text": "Which genre are you enjoying the most?",
                  "options": [
                    "I'm really enjoying rock music",
                    "I am hearing some great jazz"
                  ]
                }
              ]
            }
          },
          {
            "type": "audio_matching",
            "id": "ex5_music_genres",
            "title": "Audio: Identifica Géneros Musicales",
            "config": {
              "mode": "audio_to_text",
              "pairs": [
                {
                  "audio": "https://res.cloudinary.com/tu-usuario/audio/upload/v.../rock_music.mp3",
                  "text": "This is rock music"
                },
                {
                  "audio": "https://res.cloudinary.com/tu-usuario/audio/upload/v.../jazz_music.mp3",
                  "text": "This is jazz music"
                }
              ]
            }
          }
        ]
      }
