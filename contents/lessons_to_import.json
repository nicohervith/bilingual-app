          },
          {
            "type": "image_selection",
            "id": "ex2_health_quiz",
            "title": "Select the Symptom",
            "config": {
              "question": "Which image shows a headache?",
              "options": [
                {"image": "headache.jpg", "text": "", "correct": true},
                {"image": "broken_arm.jpg", "text": "", "correct": false}
              ]
            }
          }
        ]
      }
    },
