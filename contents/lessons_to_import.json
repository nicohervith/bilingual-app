          {
            "id": "voc_creativity",
            "word": "Creativity",
            "translation": "Creatividad",
            "examples": ["Creativity is important in art"]
          },
          {
            "id": "voc_masterpiece",
            "word": "Masterpiece",
            "translation": "Obra maestra",
            "examples": ["That painting is a true masterpiece"]
