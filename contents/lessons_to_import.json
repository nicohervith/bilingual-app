{
  "lessons": {
    "A2_changes_transformations": {
      "id": "A2_changes_transformations",
      "title": "Cambios y Transformaciones",
      "xpReward": 200,
      "metadata": {
        "level": "A2",
        "module": "grammar",
        "unit": "unitA2_changes",
        "xpReward": 200,
        "estimatedDuration": 68,
        "tags": [
          "present_simple",
          "present_continuous",
          "changes",
          "transformations",
          "progress"
        ]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_change",
            "word": "Change",
            "translation": "Cambio",
            "examples": ["I see a positive change in your work"],
            "tags": ["change", "transformation"]
          },
          {
            "id": "voc_improve",
            "word": "Improve",
            "translation": "Mejorar",
            "examples": ["My English is improving every day"],
            "tags": ["progress", "development"]
          },
          {
            "id": "voc_evolve",
            "word": "Evolve",
            "translation": "Evolucionar",
            "examples": ["Technology evolves rapidly"]
          },
          {
            "id": "voc_transform",
            "word": "Transform",
            "translation": "Transformar",
            "examples": ["The city is transforming with new buildings"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_changes_vocabulary",
            "title": "Memory: Cambios y Transformaciones",
            "config": {
              "pairs": [
                {
                  "front": "Change",
                  "back": "Cambio"
                },
                {
                  "front": "Improvement",
                  "back": "Mejora"
                },
                {
                  "front": "Transformation",
                  "back": "Transformación"
                },
                {
                  "front": "Evolution",
                  "back": "Evolución"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_change_verbs",
            "title": "Presente Simple vs Continuo - Cambios",
            "config": {
              "verb": "to improve",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Present Simple", "Present Continuous"],
              "correct": {
                "Present Simple": "improve",
                "Present Continuous": "am improving"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_change_sentences",
            "title": "Describe Cambios",
            "config": {
              "wordBank": [
                "I",
                "am",
                "improving",
                "changing",
                "evolving",
                "my",
                "English",
                "skills",
                "every",
                "day",
                "right",
                "now",
                "usually",
                "always",
                "often"
              ],
              "correctAnswers": [
                "I am improving my English every day",
                "My skills are changing right now",
                "I usually evolve with practice"
              ],
              "requiredWords": ["am", "are", "evolve"],
              "timeLimit": 130
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_change_conversation",
            "title": "Conversación sobre Cambios",
            "config": {
              "scenario": "Discussing personal changes and growth with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "How is your English improving?",
                  "options": [
                    "It's improving every day",
                    "I'm changing my study methods"
                  ]
                },
                {
                  "character": "user",
                  "text": "What changes are you making in your life?",
                  "options": [
                    "I'm evolving my daily routine",
                    "I'm transforming my habits"
                  ]
                }
              ]
            }
          },
          {
            "type": "vocabulary",
            "id": "ex5_types_of_changes",
            "title": "Categoría: Tipos de Cambios",
            "config": {
              "categories": [
                {
                  "id": "personal",
                  "name": "Cambios Personales",
                  "color": "#FF6B6B"
                },
                {
                  "id": "professional",
