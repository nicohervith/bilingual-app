      "metadata": {
        "level": "A2",
        "module": "grammar",
        "unit": "unitA2_events",
        "xpReward": 180,
        "estimatedDuration": 58,
        "tags": [
          "past_simple",
          "past_continuous",
          "events",
          "celebrations",
          "festivities"
        ]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_was_celebrating",
