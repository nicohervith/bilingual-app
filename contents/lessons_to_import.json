  "lessons": {
    "A2_education_studies": {
      "id": "A2_education_studies",
      "title": "Educación y Estudios",
      "xpReward": 185,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_education",
        "xpReward": 185,
        "estimatedDuration": 60,
        "tags": ["modal_verbs", "should", "ought_to", "education", "studies", "subjects"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_should_study",
            "word": "Should study",
            "translation": "Debería estudiar",
            "examples": ["You should study for the exam"],
            "tags": ["should", "advice"]
          },
          {
            "id": "voc_ought_to_practice",
            "word": "Ought to practice",
            "translation": "Debería practicar",
            "examples": ["We ought to practice more"],
            "tags": ["ought_to", "recommendation"]
          },
          {
            "id": "voc_homework",
            "word": "Homework",
            "translation": "Tarea",
            "examples": ["I have a lot of homework tonight"]
          },
          {
            "id": "voc_exam",
            "word": "Exam",
            "translation": "Examen",
            "examples": ["The English exam is next week"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_education_vocabulary",
            "title": "Memory: Vocabulario Educativo",
            "config": {
              "pairs": [
                {
                  "front": "Homework",
                  "back": "Tarea"
                },
                {
                  "front": "Exam",
                  "back": "Examen"
                },
                {
                  "front": "Subject",
                  "back": "Materia"
                },
                {
                  "front": "Teacher",
                  "back": "Profesor"
                }
              ]
            }
          },
          {
            "type": "drag_drop",
            "id": "ex2_study_advice",
            "title": "Consejos de Estudio: Should/Ought to",
            "config": {
              "question": "Completa los consejos educativos",
              "pairs": [
                {
                  "id": "edu1",
                  "from": "You ___ study every day",
                  "to": "should"
                },
                {
                  "id": "edu2",
                  "from": "We ___ practice speaking",
                  "to": "ought to"
                },
                {
                  "id": "edu3",
                  "from": "They ___ do their homework",
                  "to": "should"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_educational_advice",
            "title": "Forma Consejos Educativos",
            "config": {
              "wordBank": [
                "You", "should", "ought", "to", "study",
                "practice", "do", "your", "homework", "for",
                "the", "exam", "every", "day", "more"
              ],
              "correctAnswers": [
                "You should study every day",
                "You ought to practice more",
                "You should do your homework"
              ],
              "requiredWords": ["should", "ought to"],
              "timeLimit": 120
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_study_conversation",
            "title": "Conversación sobre Estudios",
            "config": {
              "scenario": "Giving study advice to a classmate",
              "dialogues": [
                {
                  "character": "classmate",
                  "text": "I have an English exam next week. What should I do?",
                  "options": ["You should study every day", "You ought to practice speaking"]
                },
                {
                  "character": "user",
                  "text": "How much time should I spend studying?",
                  "options": ["You ought to study at least one hour daily", "You should focus on vocabulary"]
                }
              ]
            }
          }
        ]
      }
    },
    "A2_free_time_hobbies": {
      "id": "A2_free_time_hobbies",
