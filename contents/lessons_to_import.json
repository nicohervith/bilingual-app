{
  "lessons": {
    "A1_abilities":{
      "id": "A1_abilities",
      "title": "Abilities and Talents",
      "xpReward": 70,
      "metadata": {
        "level": "A1",
        "module": "grammar",
        "unit": "unitA1_abilities",
        "xpReward": 70,
        "estimatedDuration": 20,
        "tags": ["can", "abilities", "talents"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_swim",
            "word": "Swim",
            "translation": "Nadar",
            "examples": ["I can swim very well"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_abilities",
            "title": "Match Abilities",
            "config": {
              "pairs": [
                {"from": "Sing", "to": "Cantar"},
                {"from": "Dance", "to": "Bailar"}
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex2_can_sentences",
            "title": "Build Can/Can't Sentences",
            "config": {
              "wordBank": ["I", "can", "can't", "play", "piano", "the"],
              "correctAnswers": ["I can play the piano", "I can't play the piano"]
            }
          }
        ]
      }
    },
