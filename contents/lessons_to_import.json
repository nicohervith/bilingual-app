        "vocabulary": [
          {
            "id": "voc_should_move",
            "word": "Should move",
            "translation": "Debería mudarse",
            "examples": ["You should move to the city for work"],
            "tags": ["should", "advice"]
          },
          {
            "id": "voc_ought_to_live",
            "word": "Ought to live",
            "translation": "Debería vivir",
            "examples": ["We ought to live in a quieter place"],
            "tags": ["ought_to", "recommendation"]
          },
          {
            "id": "voc_metropolis",
            "word": "Metropolis",
            "translation": "Metrópolis",
            "examples": ["New York is a big metropolis"]
          },
          {
            "id": "voc_countryside",
            "word": "Countryside",
            "translation": "Campo",
            "examples": ["I love the peaceful countryside"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_lifestyle_vocabulary",
            "title": "Vocabulario: Urbano vs Rural",
            "config": {
              "pairs": [
                {
                  "from": "Metropolis",
                  "to": "Metrópolis"
                },
                {
                  "from": "Countryside",
                  "to": "Campo"
                },
                {
                  "from": "Skyscraper",
                  "to": "Rascacielos"
                },
                {
                  "from": "Village",
                  "to": "Pueblo"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex2_lifestyle_advice",
            "title": "Consejos sobre Estilo de Vida",
            "config": {
              "wordBank": [
                "You",
                "should",
                "ought",
                "to",
                "move",
                "live",
                "in",
                "the",
                "city",
                "countryside",
                "for",
                "work",
                "peace",
                "quiet",
                "better",
                "opportunities",
                "life"
              ],
              "correctAnswers": [
                "You should move to the city for work",
                "You ought to live in the countryside",
                "We should find a quieter place"
              ],
              "requiredWords": ["should", "ought to"],
              "timeLimit": 125
            }
          },
          {
            "type": "conjugation",
            "id": "ex3_lifestyle_modals",
            "title": "Modales para Decisiones de Vida",
            "config": {
              "verb": "to live",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Present"],
              "correct": {
                "I": "should live",
                "You": "should live",
                "He": "should live",
                "We": "should live",
                "They": "should live"
              },
              "hints": {
                "showBaseForm": true,
                "modal": "should"
              }
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_lifestyle_discussion",
            "title": "Discusión sobre Estilo de Vida",
            "config": {
              "scenario": "Discussing where to live with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "Where should I live for better job opportunities?",
                  "options": [
                    "You should move to a big city",
                    "You ought to consider a growing town"
                  ]
                },
                {
                  "character": "user",
                  "text": "What are the benefits of rural life?",
                  "options": [
                    "You ought to enjoy the peace and quiet",
                    "You should appreciate nature more"
                  ]
                }
              ]
            }
          },
          {
            "type": "image_selection",
            "id": "ex5_urban_rural_images",
            "title": "Identifica: Urbano vs Rural",
            "config": {
              "question": "Select whether each image shows urban or rural life",
              "options": [
                {
                  "image": "https://example.com/skyscrapers.jpg",
                  "text": "Urban area with tall buildings",
                  "correct": true,
                  "feedback": "Correct! This shows urban life with skyscrapers"
                },
                {
                  "image": "https://example.com/farm_fields.jpg",
                  "text": "Rural countryside with farms",
                  "correct": false,
                  "feedback": "This shows rural life, not urban"
                }
              ],
              "multipleSelection": false
            }
          }
        ]
      }
