{
  
  "lessons": {
    "A2_future_plans": {
      "id": "A2_future_plans",
      "title": "Planes Futuros",
      "xpReward": 140,
      "metadata": {
        "level": "A2",
        "module": "grammar",
        "unit": "unitA2_future",
        "xpReward": 140,
        "estimatedDuration": 45,
        "tags": ["future_plans", "going_to", "will", "intentions"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_graduate",
            "word": "Will graduate",
            "translation": "Me graduaré",
            "examples": ["I will graduate next year"],
            "tags": ["future", "education"]
          },
          {
            "id": "voc_travel_plan",
            "word": "Going to travel",
            "translation": "Voy a viajar",
            "examples": ["I am going to travel to Europe"],
            "tags": ["future", "plans"]
          },
          {
            "id": "voc_start_business",
            "word": "Will start a business",
            "translation": "Empezaré un negocio",
            "examples": ["She will start her own business"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_future_forms",
            "title": "Diferencia entre Will y Going To",
            "config": {
              "pairs": [
                {
                  "from": "I will study medicine",
                  "to": "Decisión espontánea"
                },
                {
                  "from": "I am going to visit my family",
                  "to": "Plan previo"
                },
                {
                  "from": "It will rain tomorrow",
                  "to": "Predicción"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex2_future_sentences",
            "title": "Construye Oraciones Futuras",
            "config": {
              "wordBank": [
                "I", "will", "am", "going", "to",
                "study", "travel", "work", "buy",
                "next", "year", "month", "in", "the",
                "a", "car", "house", "university"
              ],
              "correctAnswers": [
                "I will study at the university",
                "I am going to travel next month",
                "I will buy a car next year"
              ],
              "requiredWords": ["I"],
              "timeLimit": 120
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex3_future_plans_dialogue",
            "title": "Diálogo: Planes Futuros",
            "config": {
              "scenario": "Talking about future plans with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "What are your plans for next year?",
                  "options": ["I'm going to study abroad", "I will look for a new job"]
                },
                {
                  "character": "user",
                  "text": "That sounds great! Where are you going to study?",
                  "options": ["In Canada", "I'm not sure yet"]
                }
              ]
            }
          }
        ]
      }
    },
    "A2_describing_people": {
      "id": "A2_describing_people",
      "title": "Describir Personas",
      "xpReward": 150,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_descriptions",
        "xpReward": 150,
        "estimatedDuration": 50,
        "tags": ["adjectives", "possessive", "physical_description", "personality"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_tall",
            "word": "Tall",
            "translation": "Alto/Alta",
            "examples": ["My brother is very tall"],
            "tags": ["physical", "appearance"]
          },
          {
            "id": "voc_friendly",
            "word": "Friendly",
            "translation": "Amigable",
            "examples": ["She is a friendly person"],
            "tags": ["personality"]
          },
          {
            "id": "voc_curly_hair",
            "word": "Curly hair",
            "translation": "Pelo rizado",
            "examples": ["He has curly hair"],
            "tags": ["appearance"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_adjectives_memory",
            "title": "Memory: Adjetivos de Descripción",
            "config": {
              "pairs": [
                {
                  "front": "Tall",
                  "back": "Alto/Alta"
                },
                {
                  "front": "Friendly",
                  "back": "Amigable"
                },
                {
                  "front": "Intelligent",
                  "back": "Inteligente"
                }
              ]
            }
          },
          {
            "type": "drag_drop",
            "id": "ex2_describe_people",
            "title": "Arrastra para Describir Personas",
            "config": {
              "question": "Completa las descripciones físicas",
              "pairs": [
                {
                  "id": "desc1",
                  "from": "My sister has",
                  "to": "long brown hair"
                },
                {
                  "id": "desc2",
                  "from": "He is",
                  "to": "tall and athletic"
                },
                {
                  "id": "desc3",
                  "from": "She has",
                  "to": "blue eyes"
                }
              ]
            }
          },
          {
            "type": "image_selection",
            "id": "ex3_personality_traits",
            "title": "Selecciona el Adjetivo Correcto",
            "config": {
              "question": "Choose the correct adjective for each description",
              "options": [
                {
                  "image": "https://res.cloudinary.com/dltwwat1r/image/upload/v1758555583/friendly_person_vnr51w.png",
                  "text": "Always helps others",
                  "correct": true,
                  "feedback": "Correct! This describes a friendly person"
                },
                {
                  "image": "https://res.cloudinary.com/dltwwat1r/image/upload/v1758555277/serious_person_mroqiy.png",
                  "text": "Very organized and punctual",
                  "correct": false,
                  "feedback": "This describes a serious person"
                }
              ],
              "multipleSelection": false
            }
          }
        ]
      }
    },
    "A2_weather_seasons": {
      "id": "A2_weather_seasons",
      "title": "Clima y Estaciones",
      "xpReward": 145,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_weather",
        "xpReward": 145,
        "estimatedDuration": 40,
        "tags": ["weather", "seasons", "present_simple", "present_continuous"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_sunny",
            "word": "Sunny",
            "translation": "Soleado",
            "examples": ["It is sunny today"],
            "tags": ["weather"]
          },
          {
            "id": "voc_raining",
            "word": "Raining",
            "translation": "Lloviendo",
            "examples": ["It is raining right now"],
            "tags": ["weather", "present_continuous"]
          },
          {
            "id": "voc_winter",
            "word": "Winter",
            "translation": "Invierno",
            "examples": ["I like winter because it snows"],
            "tags": ["seasons"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_weather_matching",
            "title": "Empareja Clima y Estaciones",
            "config": {
              "pairs": [
                {
                  "from": "Summer",
                  "to": "Hot and sunny"
                },
                {
                  "from": "Winter",
                  "to": "Cold and snowy"
                },
                {
                  "from": "Spring",
                  "to": "Rainy and warm"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_weather_verbs",
            "title": "Verbos del Clima",
            "config": {
              "verb": "to rain",
              "pronouns": ["It"],
              "tenses": ["Present", "Present Continuous"],
              "correct": {
                "Present": "rains",
                "Present Continuous": "is raining"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_weather_sentences",
            "title": "Describe el Clima Actual",
            "config": {
              "wordBank": [
                "It", "is", "raining", "snowing", "sunny",
                "cloudy", "windy", "today", "right", "now",
                "very", "quite", "a", "little"
              ],
              "correctAnswers": [
                "It is raining today",
                "It is sunny right now",
                "It is very windy"
              ],
              "requiredWords": ["It", "is"],
              "timeLimit": 90
            }
          },
          {
            "type": "audio_matching",
            "id": "ex4_seasons_audio",
            "title": "Audio: Clima por Estaciones",
            "config": {
              "mode": "audio_to_text",
              "pairs": [
                {
                  "audio": "https://res.cloudinary.com/dltwwat1r/video/upload/v1758555032/hotinsummer_qgpkv8.mp3",
                  "text": "It's usually hot in summer"
                },
                {
                  "audio": "https://res.cloudinary.com/dltwwat1r/video/upload/v1758555091/snows_in_winter_lhevmb.mp3",
                  "text": "It often snows in winter"
                }
              ]
            }
          }
        ]
      }
    },
