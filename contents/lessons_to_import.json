{
  "lessons": {
    "A2_travel_vacations": {
      "id": "A2_travel_vacations",
      "title": "Viajes y Vacaciones",
      "xpReward": 160,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_travel",
        "xpReward": 160,
        "estimatedDuration": 50,
        "tags": ["present_perfect", "travel", "vacations", "holiday_activities"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_visited_countries",
            "word": "Have visited",
            "translation": "He visitado",
            "examples": ["I have visited three countries"],
            "tags": ["present_perfect", "travel"]
          },
          {
            "id": "voc_beach_vacation",
            "word": "Beach vacation",
            "translation": "Vacaciones en la playa",
            "examples": ["We have been on a beach vacation"],
            "tags": ["vacations", "activities"]
          },
          {
            "id": "voc_suitcase",
            "word": "Suitcase",
            "translation": "Maleta",
            "examples": ["I have packed my suitcase"],
            "tags": ["travel_items"]
          },
          {
            "id": "voc_passport",
            "word": "Passport",
            "translation": "Pasaporte",
            "examples": ["Don't forget your passport!"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_travel_vocabulary",
            "title": "Vocabulario de Viajes",
            "config": {
              "pairs": [
                {
                  "from": "Suitcase",
                  "to": "Maleta"
                },
                {
                  "from": "Passport",
                  "to": "Pasaporte"
                },
                {
                  "from": "Hotel reservation",
                  "to": "Reserva de hotel"
                },
                {
                  "from": "Flight ticket",
                  "to": "Boleto de avión"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_present_perfect",
            "title": "Presente Perfecto - Viajes",
            "config": {
              "verb": "to travel",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Present Perfect"],
              "correct": {
                "I": "have traveled",
                "You": "have traveled",
                "He": "has traveled",
                "We": "have traveled",
                "They": "have traveled"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_vacation_experiences",
            "title": "Experiencias de Vacaciones",
            "config": {
              "wordBank": [
                "I", "have", "has", "visited", "been",
                "to", "never", "already", "just",
                "Spain", "France", "the beach", "mountains",
                "this", "year", "last", "summer"
              ],
              "correctAnswers": [
                "I have been to Spain",
                "She has visited France",
                "We have just returned from vacation"
              ],
              "requiredWords": ["have", "has"],
              "timeLimit": 120
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_travel_planning",
            "title": "Planificando un Viaje",
            "config": {
              "scenario": "Planning a vacation with friends",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "Where have you traveled before?",
                  "options": ["I have been to Mexico", "I've never traveled abroad"]
                },
                {
                  "character": "user",
                  "text": "What should we pack for the trip?",
                  "options": ["We should bring warm clothes", "Don't forget swimsuits"]
                }
              ]
            }
          }
        ]
      }
    },
    "A2_abilities_skills": {
      "id": "A2_abilities_skills",
      "title": "Habilidades y Capacidades",
      "xpReward": 155,
      "metadata": {
        "level": "A2",
        "module": "grammar",
        "unit": "unitA2_abilities",
        "xpReward": 155,
        "estimatedDuration": 45,
        "tags": ["modal_verbs", "can", "could", "abilities", "skills"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_swim",
            "word": "Can swim",
            "translation": "Puedo nadar",
            "examples": ["I can swim very well"],
            "tags": ["abilities", "can"]
          },
          {
            "id": "voc_play_instrument",
            "word": "Could play",
            "translation": "Podía tocar",
            "examples": ["I could play piano when I was young"],
            "tags": ["past_ability", "could"]
          },
          {
            "id": "voc_speak_languages",
            "word": "Can speak",
            "translation": "Puedo hablar",
            "examples": ["She can speak three languages"]
          },
          {
            "id": "voc_cook",
            "word": "Could cook",
            "translation": "Podía cocinar",
            "examples": ["He could cook when he lived alone"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_abilities_memory",
            "title": "Memory: Habilidades",
            "config": {
              "pairs": [
                {
                  "front": "Can swim",
                  "back": "Puedo nadar"
                },
                {
                  "front": "Could play",
                  "back": "Podía tocar"
                },
                {
                  "front": "Can speak",
                  "back": "Puedo hablar"
                }
              ]
            }
          },
          {
            "type": "drag_drop",
            "id": "ex2_modal_verbs",
            "title": "Can vs Could",
            "config": {
              "question": "Arrastra el verbo modal correcto",
              "pairs": [
                {
                  "id": "modal1",
                  "from": "I ___ swim when I was five",
                  "to": "could"
                },
                {
                  "id": "modal2",
                  "from": "She ___ speak French very well",
                  "to": "can"
                },
                {
                  "id": "modal3",
                  "from": "They ___ play soccer now",
                  "to": "can"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_abilities_sentences",
            "title": "Forma Oraciones con Can/Could",
            "config": {
              "wordBank": [
                "I", "you", "he", "she", "can", "could",
                "swim", "dance", "sing", "cook", "drive",
                "when", "I", "was", "young", "now", "very", "well"
              ],
              "correctAnswers": [
                "I can swim very well",
                "She could dance when she was young",
                "He can drive now"
              ],
              "requiredWords": ["can", "could"],
              "timeLimit": 100
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_skills_interview",
            "title": "Entrevista de Habilidades",
            "config": {
              "scenario": "Job interview talking about skills",
              "dialogues": [
                {
                  "character": "interviewer",
                  "text": "What languages can you speak?",
                  "options": ["I can speak English and Spanish", "I could speak French in school"]
                },
                {
                  "character": "user",
                  "text": "What software can you use?",
                  "options": ["I can use Microsoft Office", "I could learn quickly"]
                }
              ]
            }
          }
        ]
      }
    },
    "A2_family_relationships": {
      "id": "A2_family_relationships",
      "title": "Familia y Relaciones",
      "xpReward": 150,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_family",
        "xpReward": 150,
        "estimatedDuration": 48,
        "tags": ["adverbs_frequency", "family", "relationships", "family_vocabulary"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_always_visit",
            "word": "Always visit",
            "translation": "Siempre visito",
            "examples": ["I always visit my parents on weekends"],
            "tags": ["adverbs", "family"]
          },
          {
            "id": "voc_often_call",
            "word": "Often call",
            "translation": "A menudo llamo",
            "examples": ["We often call our relatives"],
            "tags": ["adverbs", "communication"]
          },
          {
            "id": "voc_siblings",
            "word": "Siblings",
            "translation": "Hermanos",
            "examples": ["I have two siblings"]
          },
          {
            "id": "voc_relatives",
            "word": "Relatives",
            "translation": "Parientes",
            "examples": ["We visit our relatives during holidays"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_family_vocabulary",
            "title": "Vocabulario Familiar",
            "config": {
              "pairs": [
                {
                  "from": "Siblings",
                  "to": "Hermanos"
                },
                {
                  "from": "Relatives",
                  "to": "Parientes"
                },
                {
                  "from": "Parents",
                  "to": "Padres"
                },
                {
                  "from": "Cousins",
                  "to": "Primos"
                }
              ]
            }
          },
          {
            "type": "drag_drop",
            "id": "ex2_adverbs_frequency",
            "title": "Adverbios de Frecuencia",
            "config": {
              "question": "Ordena los adverbios de frecuencia",
              "pairs": [
                {
                  "id": "adv1",
                  "from": "___ I visit my family",
                  "to": "Always"
                },
                {
                  "id": "adv2",
                  "from": "I ___ call my sister",
                  "to": "often"
                },
                {
                  "id": "adv3",
                  "from": "We ___ see our cousins",
                  "to": "sometimes"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_family_routines",
            "title": "Rutinas Familiares",
            "config": {
              "wordBank": [
                "I", "always", "often", "sometimes", "never",
                "visit", "call", "see", "my", "family",
                "parents", "siblings", "relatives", "on",
                "weekends", "Sundays", "holidays"
              ],
              "correctAnswers": [
                "I always visit my parents on weekends",
                "We often call our relatives",
                "They sometimes see their cousins"
              ],
              "requiredWords": ["always", "often", "sometimes"],
              "timeLimit": 110
            }
          },
          {
            "type": "image_selection",
            "id": "ex4_family_relationships",
            "title": "Selecciona la Descripción Correcta",
            "config": {
              "question": "Choose the correct family relationship",
              "options": [
                {
                  "image": "https://res.cloudinary.com/dltwwat1r/image/upload/v1758899883/parents_with_their_childrens_ubz7ol.png",
                  "text": "Parents with their children",
                  "correct": true,
                  "feedback": "Correct! This shows parents and children"
                },
                {
                  "image": "https://res.cloudinary.com/dltwwat1r/image/upload/v1758900185/siblings_z6jtuk.png",
                  "text": "Brothers and sisters together",
                  "correct": false,
                  "feedback": "This shows siblings, not parents"
                }
              ],
              "multipleSelection": false
            }
          }
        ]
      }
    },
