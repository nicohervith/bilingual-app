{
  "lessons": {
    "A1_directions": {
      "id": "A1_directions",
      "title": "Directions and City Places",
      "xpReward": 70,
      "metadata": {
        "level": "A1",
        "module": "city",
        "unit": "unitA1_city",
        "xpReward": 70,
        "estimatedDuration": 25,
        "tags": ["directions", "prepositions", "city"]
      },
      "objectives": [
        "Ask for and give directions",
        "Use prepositions of place",
        "Identify places in the city"
      ],
      "content": {
        "vocabulary": [
          {
            "id": "voc_bank",
            "word": "Bank",
            "translation": "Banco",
            "examples": ["The bank is next to the post office"],
            "media": {
              "image": "https://example.com/bank.png"
            }
          },
          {
            "id": "prep_between",
            "word": "Between",
            "translation": "Entre",
            "examples": [
              "The pharmacy is between the bank and the supermarket"
            ],
            "media": null
          }
        ],
        "exercises": [
          {
            "type": "drag_drop",
            "id": "ex1_drag_drop",
            "title": "Build directions",
            "items": [
              { "id": "dir1", "from": "Go straight" },
              { "id": "dir2", "from": "Turn left" }
            ],
            "pairs": [
              { "id": "dir1", "to": "Sigue derecho" },
              { "id": "dir2", "to": "Gira a la izquierda" }
            ],
            "question": "Match the directions"
          },
          {
            "type": "memory_game",
            "id": "ex2_memory_game",
            "title": "Match prepositions with images",
            "config": {
              "pairs": [
                {
                  "id": "prep1",
                  "front": "Next to",
                  "back": "https://example.com/next_to.png"
                },
                {
                  "id": "prep2",
                  "front": "Behind",
                  "back": "https://example.com/behind.png"
                }
              ]
            }
          },
          {
            "type": "map_interactive",
            "id": "ex3_map_interactive",
            "title": "Give directions on the map",
            "config": {
              "mapImage": "https://example.com/city_map.png",
              "scenarios": [
                {
                  "start": "You are at the bank",
                  "destination": "Post office",
                  "correctPath": ["left", "straight", "right"]
                }
              ]
            }
          }
        ]
      }
    },
    "A1_future_plans": {
      "id": "A1_future_plans",
      "title": "Future Plans",
      "xpReward": 80,
      "metadata": {
        "level": "A1",
        "module": "future",
        "unit": "unitA1_future",
        "xpReward": 80,
        "estimatedDuration": 30,
        "tags": ["future", "plans", "activities"]
      },
      "objectives": [
        "Use 'going to' for future plans",
        "Talk about activities and events"
      ],
      "content": {
        "vocabulary": [
          {
            "id": "act_movie",
            "word": "Watch a movie",
            "translation": "Ver una película",
            "media": {
              "image": "https://example.com/movie.png"
            }
          }
        ],
        "exercises": [
          {
            "type": "conjugation",
            "id": "ex1_conjugation",
            "title": "Practice 'going to'",
            "config": {
              "verb": "to go",
              "tenses": ["future"],
              "pronouns": ["I", "We"],
              "correct": {
                "future": {
                  "I": "am going to",
                  "We": "are going to"
                }
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex2_sentence_formation",
            "title": "Build future plans",
            "config": {
              "wordBank": [
                "I",
                "am",
                "going",
                "to",
                "travel",
                "next",
                "summer"
              ],
              "correctAnswers": ["I am going to travel next summer"],
              "timeLimit": 90
            }
          },
          {
            "type": "calendar_planner",
            "id": "ex3_calendar_planner",
            "title": "Plan a week schedule",
            "config": {
              "activities": ["Doctor appointment", "Dinner with friends"],
              "constraints": {
                "maxActivitiesPerDay": 3
              }
            }
          }
        ]
      }
    },
    "A1_food_restaurants": {
      "id": "A1_food_restaurants",
      "title": "Food and Restaurants",
      "xpReward": 90,
      "metadata": {
        "level": "A1",
        "module": "food",
        "unit": "unitA1_food",
        "xpReward": 90,
        "estimatedDuration": 35,
        "tags": ["food", "restaurant", "countable"]
      },
      "objectives": [
        "Order food in a restaurant",
        "Distinguish countable/uncountable nouns"
      ],
      "content": {
        "vocabulary": [
          {
            "id": "food_water",
            "word": "Water",
            "translation": "Agua",
            "tags": ["uncountable"],
            "media": {
              "image": "https://example.com/water.png"
            }
          }
        ],
        "exercises": [
          {
            "type": "categorization",
            "id": "ex1_categorization",
            "title": "Countable or Uncountable?",
            "config": {
              "categories": ["Countable", "Uncountable"],
              "items": [
                {
                  "id": "item1",
                  "content": "Apple",
                  "correctCategory": "Countable"
                },
                {
                  "id": "item2",
                  "content": "Rice",
                  "correctCategory": "Uncountable"
                }
              ]
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex2_dialogue_simulation",
            "title": "Restaurant Conversation",
            "config": {
              "scenario": "Ordering food",
              "phrases": {
                "Waiter": ["What would you like to drink?"],
                "UserOptions": ["I'll have water", "Can I see the menu?"]
              }
            }
          },
          {
            "type": "audio_matching",
            "title": "Match food pronunciations",
            "id": "ex3_audio_matching",
            "config": {
              "mode": "audio_to_image",
              "pairs": [
                {
                  "audio": "https://example.com/pasta_audio.mp3",
                  "image": "https://example.com/pasta.png"
                }
              ]
            }
          }
        ]
      }
    }
  }
}
