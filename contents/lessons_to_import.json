{
  "lessons": {
    "A2_technology_social_media": {
      "id": "A2_technology_social_media",
      "title": "Tecnología y Redes Sociales",
      "xpReward": 170,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_technology",
        "xpReward": 170,
        "estimatedDuration": 50,
        "tags": [
          "adverbs_frequency",
          "technology",
          "social_media",
          "digital_life"
        ]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_always_online",
            "word": "Always online",
            "translation": "Siempre en línea",
            "examples": ["I am always online in the evening"],
            "tags": ["adverbs", "technology"]
          },
          {
            "id": "voc_often_post",
            "word": "Often post",
            "translation": "A menudo publico",
            "examples": ["She often posts photos on Instagram"],
            "tags": ["adverbs", "social_media"]
          },
          {
            "id": "voc_smartphone",
            "word": "Smartphone",
            "translation": "Teléfono inteligente",
            "examples": ["I use my smartphone every day"]
          },
          {
            "id": "voc_wifi",
            "word": "Wi-Fi",
            "translation": "Wi-Fi",
            "examples": ["The Wi-Fi connection is very fast"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_tech_vocabulary",
            "title": "Memory: Vocabulario Tecnológico",
            "config": {
              "pairs": [
                {
                  "front": "Smartphone",
                  "back": "Teléfono inteligente"
                },
                {
                  "front": "Wi-Fi",
                  "back": "Wi-Fi"
                },
                {
                  "front": "Social media",
                  "back": "Redes sociales"
                },
                {
                  "front": "Download",
                  "back": "Descargar"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex2_digital_habits",
            "title": "Hábitos Digitales con Adverbios",
            "config": {
              "wordBank": [
                "I",
                "always",
                "often",
                "sometimes",
                "never",
                "use",
                "check",
                "post",
                "on",
                "social",
                "media",
                "my",
                "phone",
                "computer",
                "in",
                "the",
                "morning",
                "evening"
              ],
              "correctAnswers": [
                "I always use my phone in the morning",
                "I often check social media",
                "I never post on social media"
              ],
              "requiredWords": ["always", "often", "sometimes", "never"],
              "timeLimit": 120
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex3_social_media_talk",
            "title": "Conversación sobre Redes Sociales",
            "config": {
              "scenario": "Talking about social media habits with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "How often do you use social media?",
                  "options": [
                    "I always check it in the morning",
                    "I sometimes post photos"
                  ]
                },
                {
                  "character": "user",
                  "text": "Which app do you use the most?",
                  "options": ["I often use Instagram", "I always use WhatsApp"]
                }
              ]
            }
          },
          {
            "type": "matching",
            "id": "ex4_tech_adverbs",
            "title": "Adverbios de Frecuencia Tecnológicos",
            "config": {
              "pairs": [
                {
                  "from": "Always",
                  "to": "100% del tiempo"
                },
                {
                  "from": "Often",
                  "to": "Frecuentemente"
                },
                {
                  "from": "Sometimes",
                  "to": "Algunas veces"
                },
                {
                  "from": "Never",
                  "to": "Nunca"
                }
              ]
            }
          }
        ]
      }
    },
    "A2_nature_environment": {
      "id": "A2_nature_environment",
      "title": "Naturaleza y Medio Ambiente",
      "xpReward": 175,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_nature",
        "xpReward": 175,
        "estimatedDuration": 55,
        "tags": [
          "modal_verbs",
          "must",
          "have_to",
          "nature",
          "environment",
          "ecology"
        ]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_must_recycle",
            "word": "Must recycle",
            "translation": "Debo reciclar",
            "examples": ["We must recycle to protect the environment"],
            "tags": ["must", "environment"]
          },
          {
            "id": "voc_have_to_save",
            "word": "Have to save",
            "translation": "Tengo que ahorrar",
            "examples": ["We have to save water"],
            "tags": ["have_to", "conservation"]
          },
          {
            "id": "voc_recycling",
            "word": "Recycling",
            "translation": "Reciclaje",
            "examples": ["Recycling is important for the planet"]
          },
          {
            "id": "voc_pollution",
            "word": "Pollution",
            "translation": "Contaminación",
            "examples": ["Air pollution is a big problem"]
          }
        ],
        "exercises": [
          {
            "type": "drag_drop",
            "id": "ex1_environmental_rules",
            "title": "Normas Ambientales: Must/Have to",
            "config": {
              "question": "Completa las normas ambientales",
              "pairs": [
                {
                  "id": "env1",
                  "from": "We ___ recycle plastic",
                  "to": "must"
                },
                {
                  "id": "env2",
                  "from": "You ___ turn off the lights",
                  "to": "have to"
                },
                {
                  "id": "env3",
                  "from": "They ___ save water",
                  "to": "must"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_environmental_verbs",
            "title": "Conjugación: Must y Have to",
            "config": {
              "verb": "to recycle",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Present"],
              "correct": {
                "I": "must recycle",
                "You": "must recycle",
                "He": "must recycle",
                "We": "must recycle",
                "They": "must recycle"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_eco_sentences",
            "title": "Forma Oraciones Ecológicas",
            "config": {
              "wordBank": [
                "We",
                "must",
                "have",
                "to",
                "recycle",
                "save",
                "water",
                "energy",
                "protect",
                "the",
                "environment",
                "planet",
                "trees"
              ],
              "correctAnswers": [
                "We must recycle",
                "We have to save water",
                "We must protect the environment"
              ],
              "requiredWords": ["must", "have to"],
              "timeLimit": 110
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_eco_conversation",
            "title": "Conversación sobre Ecología",
            "config": {
              "scenario": "Discussing environmental protection with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "What must we do to help the environment?",
                  "options": [
                    "We must recycle more",
                    "We have to use less plastic"
                  ]
                },
                {
                  "character": "user",
                  "text": "Why is it important to save water?",
                  "options": [
                    "Because water is limited",
                    "To protect our planet"
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "A2_shopping_prices": {
      "id": "A2_shopping_prices",
      "title": "Compras y Precios",
      "xpReward": 165,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_shopping",
        "xpReward": 165,
        "estimatedDuration": 52,
        "tags": [
          "modal_verbs",
          "can",
          "could",
          "may",
          "shopping",
          "prices",
          "stores"
        ]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_can_buy",
            "word": "Can buy",
            "translation": "Puedo comprar",
            "examples": ["I can buy this shirt"],
            "tags": ["can", "shopping"]
          },
          {
            "id": "voc_could_try",
            "word": "Could try",
            "translation": "Podría probar",
            "examples": ["I could try a smaller size"],
            "tags": ["could", "suggestions"]
          },
          {
            "id": "voc_may_help",
            "word": "May help",
            "translation": "Puede ayudar",
            "examples": ["May I help you?"],
            "tags": ["may", "offers"]
          },
          {
            "id": "voc_discount",
            "word": "Discount",
            "translation": "Descuento",
            "examples": ["This shirt has a 20% discount"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_shopping_modals",
            "title": "Modales en Compras: Can/Could/May",
            "config": {
              "pairs": [
                {
                  "from": "Can I help you?",
                  "to": "Ofrecimiento de ayuda"
                },
                {
                  "from": "Could I try this?",
                  "to": "Petición educada"
                },
                {
                  "from": "May I pay by card?",
                  "to": "Pregunta formal"
                }
              ]
            }
          },
          {
            "type": "drag_drop",
            "id": "ex2_shopping_phrases",
            "title": "Completa Frases de Compras",
            "config": {
              "question": "Arrastra el verbo modal correcto",
              "pairs": [
                {
                  "id": "shop1",
                  "from": "___ I help you?",
                  "to": "May"
                },
                {
                  "id": "shop2",
                  "from": "I ___ buy this dress",
                  "to": "can"
                },
                {
                  "id": "shop3",
                  "from": "___ I try it on?",
                  "to": "Could"
                }
              ]
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex3_store_conversation",
            "title": "Simulación: Tienda de Ropa",
            "config": {
              "scenario": "Shopping for clothes in a store",
              "dialogues": [
                {
                  "character": "assistant",
                  "text": "May I help you?",
                  "options": [
                    "Yes, I'm looking for a dress",
                    "No, I'm just looking"
                  ]
                },
                {
                  "character": "user",
                  "text": "Could I try this in a smaller size?",
                  "options": [
                    "Of course, I'll get it for you",
                    "Yes, the fitting room is there"
                  ]
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex4_shopping_requests",
            "title": "Forma Peticiones de Compra",
            "config": {
              "wordBank": [
                "Can",
                "Could",
                "May",
                "I",
                "you",
                "help",
                "buy",
                "try",
                "this",
                "on",
                "pay",
                "by",
                "card",
                "cash",
                "have",
                "a",
                "discount"
              ],
              "correctAnswers": [
                "Can I try this on?",
                "May I pay by card?",
                "Could you help me?"
              ],
              "requiredWords": ["Can", "Could", "May"],
              "timeLimit": 100
            }
          }
        ]
      }
    },
    "A2_events_celebrations": {
      "id": "A2_events_celebrations",
      "title": "Eventos y Celebraciones",
