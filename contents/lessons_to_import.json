        "exercises": [
          {
            "type": "matching",
            "id": "ex1_hobbies_matching",
            "title": "Empareja Pasatiempos",
            "config": {
              "pairs": [
                {
                  "from": "Reading books",
                  "to": "Leer libros"
                },
                {
                  "from": "Watching movies",
                  "to": "Ver películas"
                },
                {
                  "from": "Listening to music",
                  "to": "Escuchar música"
                },
                {
                  "from": "Playing sports",
                  "to": "Practicar deportes"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_stative_verbs",
            "title": "Verbos Estativos en Presente",
            "config": {
              "verb": "to like",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Present"],
              "correct": {
                "I": "like",
                "You": "like",
                "He": "likes",
                "We": "like",
                "They": "like"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_hobby_sentences",
            "title": "Describe tus Pasatiempos",
            "config": {
              "wordBank": [
                "I", "like", "enjoy", "love", "reading",
                "watching", "listening", "to", "music", "movies",
                "books", "in", "my", "free", "time", "weekends"
              ],
              "correctAnswers": [
                "I like reading books",
                "I enjoy watching movies",
                "I love listening to music"
              ],
              "requiredWords": ["like", "enjoy", "love"],
              "timeLimit": 110
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_hobbies_conversation",
            "title": "Conversación sobre Pasatiempos",
            "config": {
              "scenario": "Talking about hobbies with a new friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "What do you like doing in your free time?",
                  "options": ["I like reading and watching movies", "I enjoy playing sports"]
                },
                {
                  "character": "user",
                  "text": "What kind of music do you enjoy?",
                  "options": ["I love listening to pop music", "I enjoy different types of music"]
                }
              ]
            }
          }
        ]
      }
