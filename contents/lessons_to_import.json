    "A2_music_concerts": {
      "id": "A2_music_concerts",
      "title": "Música y Conciertos",
      "xpReward": 195,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_music",
        "xpReward": 195,
