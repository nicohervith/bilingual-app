            "translation": "Estaba celebrando",
            "examples": ["I was celebrating my birthday when you called"],
            "tags": ["past_continuous", "events"]
          },
          {
            "id": "voc_arrived",
            "word": "Arrived",
            "translation": "Llegó",
            "examples": ["She arrived at the party at 8 PM"],
            "tags": ["past_simple", "actions"]
          },
          {
            "id": "voc_birthday_party",
            "word": "Birthday party",
            "translation": "Fiesta de cumpleaños",
            "examples": ["We had a birthday party last weekend"]
          },
          {
            "id": "voc_wedding",
            "word": "Wedding",
            "translation": "Boda",
            "examples": ["The wedding was beautiful"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_events_vocabulary",
            "title": "Memory: Eventos y Celebraciones",
            "config": {
              "pairs": [
                {
                  "front": "Birthday party",
                  "back": "Fiesta de cumpleaños"
                },
                {
                  "front": "Wedding",
                  "back": "Boda"
                },
                {
                  "front": "Anniversary",
                  "back": "Aniversario"
                },
                {
                  "front": "Graduation",
                  "back": "Graduación"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_past_tenses",
            "title": "Pasado Simple vs Pasado Continuo",
            "config": {
              "verb": "to celebrate",
              "pronouns": ["I", "You", "He", "We"],
              "tenses": ["Past Simple", "Past Continuous"],
              "correct": {
                "Past Simple": "celebrated",
                "Past Continuous": "was celebrating"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_event_stories",
            "title": "Cuenta Historias de Eventos",
            "config": {
              "wordBank": [
                "I",
                "was",
                "were",
                "celebrating",
                "dancing",
                "when",
                "arrived",
                "called",
                "came",
                "to",
                "the",
                "party",
                "wedding",
                "birthday",
                "last",
                "night",
                "weekend"
              ],
              "correctAnswers": [
                "I was celebrating when you called",
                "We were dancing at the party",
                "She arrived at the wedding"
              ],
              "requiredWords": ["was", "were", "arrived"],
              "timeLimit": 130
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_party_conversation",
            "title": "Conversación sobre un Evento",
            "config": {
              "scenario": "Talking about a recent celebration with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "What were you doing last night?",
                  "options": [
                    "I was celebrating my birthday",
                    "We were at a wedding"
                  ]
                },
                {
                  "character": "user",
                  "text": "When did the party start?",
                  "options": ["It started at 7 PM", "People arrived around 8"]
                }
              ]
            }
          },
          {
            "type": "audio_matching",
            "id": "ex5_events_audio",
            "title": "Audio: Descripciones de Eventos",
            "config": {
              "mode": "audio_to_text",
              "pairs": [
                {
                  "audio": "https://res.cloudinary.com/tu-usuario/video/upload/v.../birthday_party.mp3",
                  "text": "I was celebrating my birthday yesterday"
                },
                {
                  "audio": "https://res.cloudinary.com/tu-usuario/video/upload/v.../wedding_arrival.mp3",
                  "text": "We arrived at the wedding at 6 PM"
                }
