    "A1_simple_present": {
      "id": "A1_simple_present",
      "unit": "unitA1_verbs",
      "title": "Simple Present",
      "type": "grammar",
      "xpReward": 60,
      "objectives": [
        "Conjugar verbos en presente simple",
        "Formar oraciones afirmativas"
      ],
      "content": {
        "conjugation": {
          "I": "work",
          "You": "work",
          "He/She/It": "works",
          "We/They": "work"
        },
        "examples": ["I eat breakfast at 7am", "She works in an office"],
        "exercises": [
          {
            "type": "conjugation",
            "verb": "to eat",
            "pronouns": ["I", "She", "They"]
          },
          {
            "type": "sentence_formation",
            "words": ["She", "work", "hospital"],
            "correct": "She works in a hospital"
          }
        ]
      }
    },
