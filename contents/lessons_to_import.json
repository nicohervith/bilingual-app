              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_reflexives",
            "title": "Reflexive Pronouns",
            "config": {
              "pronouns": ["I", "You", "He"],
              "correct": {
                "I": "myself",
                "You": "yourself",
                "He": "himself"
              }
            }
          }
        ]
      }
    },
