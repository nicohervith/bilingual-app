    "A1_future_plans_will": {
      "id": "A1_future_plans_will",
      "title": "Planes Futuros con Will",
      "xpReward": 58,
      "metadata": {
        "level": "A1",
        "module": "grammar",
        "unit": "unitA1_future_will",
        "xpReward": 58,
        "estimatedDuration": 29,
        "tags": ["future", "will", "plans", "intentions"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_will_travel",
            "word": "Will travel",
            "translation": "Viajaré",
            "examples": ["I will travel next year"],
            "tags": ["future", "will"]
          },
          {
            "id": "voc_will_study",
            "word": "Will study",
            "translation": "Estudiaré",
            "examples": ["She will study English"],
            "tags": ["future", "will"]
          },
          {
            "id": "voc_tomorrow",
            "word": "Tomorrow",
            "translation": "Mañana",
            "examples": ["I will see you tomorrow"]
          },
          {
            "id": "voc_next_week",
            "word": "Next week",
            "translation": "La próxima semana",
            "examples": ["We will meet next week"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_future_expressions",
            "title": "Empareja Expresiones Futuras",
            "config": {
              "pairs": [
                {
                  "from": "Tomorrow",
                  "to": "Mañana"
                },
                {
                  "from": "Next week",
                  "to": "La próxima semana"
                },
                {
                  "from": "Will travel",
                  "to": "Viajaré"
                },
                {
                  "from": "Will study",
                  "to": "Estudiaré"
                }
              ]
            }
          },
          {
            "type": "pronunciation",
            "id": "ex2_future_pronunciation",
            "title": "Pronunciación: Planes Futuros",
            "config": {
              "phrase": "I will travel to Spain next year",
              "translation": "Viajaré a España el próximo año",
              "language": "en-US"
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_future_sentences",
            "title": "Forma Frases Futuras",
            "config": {
              "wordBank": [
                "I",
                "will",
                "travel",
                "study",
                "work",
                "tomorrow",
                "next",
                "week",
                "year",
                "to",
                "Spain",
                "English",
                "new",
                "job"
              ],
              "correctAnswers": [
                "I will travel to Spain",
                "She will study English",
                "We will work tomorrow"
              ],
              "requiredWords": ["will"],
              "timeLimit": 70
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_future_plans",
            "title": "Simulación: Planes Futuros",
            "config": {
              "scenario": "Talking about future plans with a friend",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "What will you do next year?",
                  "options": [
                    "I will travel to Europe",
                    "I will study at university"
                  ]
                },
                {
                  "character": "user",
                  "text": "Will you work next month?",
                  "options": [
                    "Yes, I will start a new job",
                    "No, I will travel first"
                  ]
                }
              ]
            }
          }
        ]
      }
