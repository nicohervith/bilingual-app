            "image": "colors/blue.png",
            "examples": ["The sky is blue", "The ocean is blue"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "title": "Match words",
            "pairs": [
              { "from": "Red", "to": "Rojo" },
              { "from": "Blue", "to": "Azul" }
            ]
          },
          {
            "type": "image_selection",
            "title": "Select the correct color",
            "question": "Which image shows something blue?",
            "options": [
              { "image": "colors/red_car.png", "isCorrect": false },
              { "image": "colors/blue_sky.png", "isCorrect": true }
            ]
          }
        ]
      },
      "metadata": {
        "createdAt": "2023-11-20",
        "version": 1
      }
    },
    "A1_articles": {
      "id": "A1_articles",
      "unit": "unitA1_grammar",
      "title": "Articles: A vs An",
      "type": "grammar",
      "xpReward": 50,
      "objectives": [
        "Diferenciar entre 'a' y 'an'",
        "Aplicar la regla de sonido vocálico"
      ],
      "content": {
        "grammarRules": [
          {
            "rule": "Use 'a' before consonant sounds",
            "examples": ["a dog", "a university"]
          },
          {
            "rule": "Use 'an' before vowel sounds",
            "examples": ["an apple", "an hour"]
          }
        ],
        "exercises": [
          {
            "type": "fill_blank",
            "questions": [
              {
                "sentence": "I have ___ apple",
                "answer": "an",
                "options": ["a", "an"]
              },
              {
                "sentence": "She is ___ doctor",
                "answer": "a",
                "options": ["a", "an"]
              }
            ]
          }
        ]
      }
    },
