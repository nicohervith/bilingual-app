{
  "lessons": {
    "A1_greetings": {
      "id": "A1_greetings",
      "title": "Greetings and Introductions",
      "level": "A1",
      "module": "basics",
      "unit": "unitA1_basics",
      "type": "vocabulary",
      "xpReward": 40,
      "objectives": ["Use basic greetings", "Introduce yourself and others"],
      "content": {
        "vocabulary": [
          {
            "word": "Hello",
            "translation": "Hola",
            "examples": ["Hello, my name is John", "Hello, how are you?"],
            "image": "https://example.com/hello_image.png"
          },
          {
            "word": "Goodbye",
            "translation": "Adiós",
            "examples": [
              "Goodbye, see you tomorrow!",
              "It's time to say goodbye"
            ],
            "image": "https://example.com/goodbye_image.png"
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "title": "Match greetings",
            "pairs": [
              {
                "word": "Hello",
                "image": "https://example.com/hello_image.png"
              },
              {
                "word": "Goodbye",
                "image": "https://example.com/goodbye_image.png"
              }
            ]
          },
          {
            "type": "conjugation",
            "title": "Complete with 'to be'",
            "verb": "to be",
            "pronouns": ["I", "You", "He"],
            "correct": { "I": "am", "You": "are", "He": "is" }
          }
        ]
      }
    },
    "A1_nationalities": {
      "id": "A1_nationalities",
      "title": "Countries and Nationalities",
      "level": "A1",
      "module": "basics",
      "unit": "unitA1_basics",
      "type": "vocabulary",
      "xpReward": 45,
      "objectives": [
        "Identify countries and nationalities",
        "Use personal and possessive pronouns"
      ],
      "content": {
        "vocabulary": [
          {
            "word": "Spain",
            "translation": "España",
            "examples": ["I am from Spain", "She lives in Spain"],
            "image": "https://example.com/spain_flag.png"
          },
          {
            "word": "Mexican",
            "translation": "Mexicano/a",
            "examples": ["He is Mexican", "Mexican food is delicious"],
            "image": "https://example.com/mexico_flag.png"
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "title": "Match countries with nationalities",
            "pairs": [
              {
                "word": "Spain",
                "image": "https://example.com/spain_flag.png"
              },
              {
                "word": "Spanish",
                "image": "https://example.com/spanish_person.png"
              }
            ]
          },
          {
            "type": "sentence_formation",
            "title": "Complete the sentence",
            "words": ["She", "is", "from", "Brazil", "Brazilian"],
            "required": ["She", "is", "from", "Brazil"],
            "correct": "She is from Brazil"
          }
        ]
      }
    },
    "A1_personal_info": {
      "id": "A1_personal_info",
      "title": "Personal Information",
      "level": "A1",
      "module": "basics",
      "unit": "unitA1_basics",
      "type": "vocabulary",
      "xpReward": 50,
      "objectives": [
        "Ask for and give personal information",
        "Use numbers and family vocabulary"
      ],
      "content": {
        "vocabulary": [
          {
            "word": "Age",
            "translation": "Edad",
            "examples": ["What is your age?", "My age is 25"],
            "image": "https://example.com/age_image.png"
          },
          {
            "word": "Family",
            "translation": "Familia",
            "examples": ["My family is big", "Family is important"],
            "image": "https://example.com/family_image.png"
          }
        ],
        "exercises": [
          {
            "type": "numbers_game",
            "title": "Listen and match numbers",
            "modes": ["listen_match", "write_number"],
            "options": {
              "range": [1, 100],
              "imageBaseUrl": "https://example.com/numbers/"
            }
          },
          {
            "type": "matching",
            "title": "Match family members",
            "pairs": [
              { "word": "Mother", "image": "https://example.com/mother.png" },
              { "word": "Father", "image": "https://example.com/father.png" }
            ]
          }
        ]
      }
    },
    "A1_descriptions": {
      "id": "A1_descriptions",
      "title": "Physical Descriptions",
      "level": "A1",
      "module": "basics",
      "unit": "unitA1_basics",
      "type": "vocabulary",
      "xpReward": 55,
      "objectives": [
        "Describe people's appearance",
        "Use possessive adjectives"
      ],
      "content": {
        "vocabulary": [
          {
            "word": "Tall",
            "translation": "Alto/a",
            "examples": ["He is very tall", "The tall building"],
            "image": "https://example.com/tall_person.png"
          },
          {
            "word": "Blonde",
            "translation": "Rubio/a",
            "examples": ["She has blonde hair", "The blonde boy"],
            "image": "https://example.com/blonde_person.png"
          }
        ],
        "exercises": [
          {
            "type": "image_selection",
            "title": "Select the correct description",
            "question": "Which person is tall?",
            "options": [
              {
                "image": "https://example.com/tall_person.png",
                "correct": true
              },
              {
                "image": "https://example.com/short_person.png",
                "correct": false
              }
            ]
          },
          {
            "type": "sentence_formation",
            "title": "Describe this person",
            "words": ["My", "sister", "has", "long", "hair", "black"],
            "required": ["My", "sister", "has", "long", "hair"],
            "correct": "My sister has long hair"
          }
        ]
      }
    },
    "A1_daily_routine": {
      "id": "A1_daily_routine",
      "title": "Daily Routine",
      "level": "A1",
      "module": "basics",
      "unit": "unitA1_basics",
      "type": "vocabulary",
      "xpReward": 60,
      "objectives": [
        "Talk about daily activities",
        "Use regular verbs in simple present"
      ],
      "content": {
        "vocabulary": [
          {
            "word": "Wake up",
            "translation": "Despertarse",
            "examples": ["I wake up at 7am", "She wakes up early"],
            "image": "https://example.com/wake_up.png"
          },
          {
            "word": "Work",
            "translation": "Trabajar",
            "examples": ["They work in an office", "I work from home"],
            "image": "https://example.com/work_image.png"
          }
        ],
        "exercises": [
          {
            "type": "sentence_formation",
            "title": "Order the routine",
            "words": ["I", "at", "7am", "wake up", "usually"],
            "required": ["I", "usually", "wake up", "at", "7am"],
            "correct": "I usually wake up at 7am"
          },
          {
            "type": "conjugation",
            "title": "Conjugate regular verbs",
            "verb": "to work",
            "pronouns": ["I", "She", "We"],
            "correct": { "I": "work", "She": "works", "We": "work" }
          }
        ]
      }
    },
    "A1_time_expressions": {
      "id": "A1_time_expressions",
      "title": "Time and Schedules",
      "level": "A1",
      "module": "basics",
      "unit": "unitA1_basics",
      "type": "vocabulary",
      "xpReward": 45,
      "objectives": ["Tell time", "Use irregular verbs in simple present"],
      "content": {
        "vocabulary": [
          {
            "word": "Morning",
            "translation": "Mañana",
            "examples": ["I study in the morning", "Good morning!"],
            "image": "https://example.com/morning_image.png"
          },
          {
            "word": "Evening",
            "translation": "Tarde/noche",
            "examples": ["We eat dinner in the evening", "Good evening!"],
            "image": "https://example.com/evening_image.png"
          }
        ],
        "exercises": [
          {
            "type": "numbers_game",
            "title": "Tell the time",
            "modes": ["listen_match", "write_number"],
            "options": {
              "range": [1, 12],
              "imageBaseUrl": "https://example.com/clock_images/"
            }
          },
          {
            "type": "conjugation",
            "title": "Conjugate 'to go'",
            "verb": "to go",
            "pronouns": ["I", "She", "They"],
            "correct": { "I": "go", "She": "goes", "They": "go" }
          }
        ]
      }
    },
    "A1_likes_dislikes": {
      "id": "A1_likes_dislikes",
      "title": "Likes and Dislikes",
      "level": "A1",
      "module": "basics",
      "unit": "unitA1_basics",
      "type": "vocabulary",
      "xpReward": 50,
      "objectives": ["Express preferences", "Use modal verbs"],
      "content": {
        "vocabulary": [
          {
            "word": "Music",
            "translation": "Música",
            "examples": ["I like music", "She listens to music"],
            "image": "https://example.com/music_image.png"
          },
          {
            "word": "Sports",
            "translation": "Deportes",
            "examples": ["He plays sports", "Do you like sports?"],
            "image": "https://example.com/sports_image.png"
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "title": "Match words",
            "pairs": [
              { "from": "I like", "to": "Me gusta" },
              { "from": "You like", "to": "Te gusta" },
              { "from": "Music", "to": "Música" },
              { "from": "Sports", "to": "Deportes" }
            ]
          },
          {
            "type": "image_selection",
            "title": "Select the correct image",
            "question": "Which image shows someone who likes music?",
            "options": [
              {
                "image": "https://example.com/person_listening_music.png",
                "isCorrect": true
              },
              {
                "image": "https://example.com/person_playing_sports.png",
                "isCorrect": false
              }
            ]
          }
        ]
      }
    }
  }

}
