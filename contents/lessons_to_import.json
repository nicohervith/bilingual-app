{
  "lessons": {
    "A2_health_symptoms": {
      "id": "A2_health_symptoms",
      "title": "Salud y Síntomas",
      "xpReward": 170,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_health",
        "xpReward": 170,
        "estimatedDuration": 55,
        "tags": ["modal_verbs", "should", "shouldnt", "health", "medical", "symptoms"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_should_rest",
            "word": "Should rest",
            "translation": "Debería descansar",
            "examples": ["You should rest if you're sick"],
            "tags": ["should", "advice"]
          },
          {
            "id": "voc_shouldnt_smoke",
            "word": "Shouldn't smoke",
            "translation": "No debería fumar",
            "examples": ["You shouldn't smoke when you're sick"],
            "tags": ["shouldnt", "prohibition"]
          },
          {
            "id": "voc_headache",
            "word": "Headache",
            "translation": "Dolor de cabeza",
            "examples": ["I have a headache"],
            "tags": ["symptoms"]
          },
          {
            "id": "voc_fever",
            "word": "Fever",
            "translation": "Fiebre",
            "examples": ["She has a fever and should see a doctor"]
          },
          {
            "id": "voc_medicine",
            "word": "Medicine",
            "translation": "Medicina",
            "examples": ["You should take this medicine"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_health_vocabulary",
            "title": "Vocabulario Médico",
            "config": {
              "pairs": [
                {
                  "from": "Headache",
                  "to": "Dolor de cabeza"
                },
                {
                  "from": "Fever",
                  "to": "Fiebre"
                },
                {
                  "from": "Medicine",
                  "to": "Medicina"
                },
                {
                  "from": "Doctor",
                  "to": "Doctor/Doctora"
                }
              ]
            }
          },
          {
            "type": "drag_drop",
            "id": "ex2_health_advice",
            "title": "Consejos de Salud: Should/Shouldn't",
            "config": {
              "question": "Arrastra el consejo médico correcto",
              "pairs": [
                {
                  "id": "advice1",
                  "from": "If you have a fever, you ___ see a doctor",
                  "to": "should"
                },
                {
                  "id": "advice2",
                  "from": "You ___ smoke when you're sick",
                  "to": "shouldn't"
                },
                {
                  "id": "advice3",
                  "from": "You ___ drink more water",
                  "to": "should"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_medical_sentences",
            "title": "Forma Consejos Médicos",
            "config": {
              "wordBank": [
                "You", "should", "shouldn't", "see", "take",
                "drink", "a", "doctor", "medicine", "water",
                "rest", "if", "you", "have", "fever", "headache"
              ],
              "correctAnswers": [
                "You should see a doctor",
                "You shouldn't smoke",
                "You should drink more water"
              ],
              "requiredWords": ["should", "shouldn't"],
              "timeLimit": 120
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_doctor_visit",
            "title": "Simulación: Visita al Doctor",
            "config": {
              "scenario": "Talking to a doctor about symptoms",
              "dialogues": [
                {
                  "character": "doctor",
                  "text": "What symptoms do you have?",
                  "options": ["I have a headache and fever", "I feel very tired"]
                },
                {
                  "character": "user",
                  "text": "What should I do?",
                  "options": ["You should rest and drink water", "You shouldn't go to work today"]
                }
              ]
            }
          },
          {
            "type": "memory_game",
            "id": "ex5_symptoms_memory",
            "title": "Memory: Síntomas y Consejos",
            "config": {
              "pairs": [
                {
                  "front": "Headache",
                  "back": "You should rest"
                },
                {
                  "front": "Fever",
                  "back": "You should see a doctor"
                },
                {
                  "front": "Cough",
                  "back": "You shouldn't smoke"
                }
              ]
            }
          }
        ]
      }
    },
    "A2_work_professions": {
      "id": "A2_work_professions",
      "title": "Trabajo y Profesiones",
      "xpReward": 165,
      "metadata": {
        "level": "A2",
        "module": "vocabulary",
        "unit": "unitA2_work",
        "xpReward": 165,
        "estimatedDuration": 50,
        "tags": ["present_continuous", "work", "professions", "jobs", "careers"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_working",
            "word": "Working",
            "translation": "Trabajando",
            "examples": ["I am working on a new project"],
            "tags": ["present_continuous", "work"]
          },
          {
            "id": "voc_meeting",
            "word": "Having a meeting",
            "translation": "Teniendo una reunión",
            "examples": ["They are having a meeting right now"],
            "tags": ["present_continuous", "work_activities"]
          },
          {
            "id": "voc_teacher",
            "word": "Teacher",
            "translation": "Maestro/Profesor",
            "examples": ["She is a teacher at the school"]
          },
          {
            "id": "voc_engineer",
            "word": "Engineer",
            "translation": "Ingeniero/Ingeniera",
            "examples": ["He is working as an engineer"]
          },
          {
            "id": "voc_office",
            "word": "Office",
            "translation": "Oficina",
            "examples": ["I am working in the office today"]
          }
        ],
        "exercises": [
          {
            "type": "memory_game",
            "id": "ex1_professions_memory",
            "title": "Memory: Profesiones",
            "config": {
              "pairs": [
                {
                  "front": "Teacher",
                  "back": "Maestro/Profesor"
                },
                {
                  "front": "Engineer",
                  "back": "Ingeniero/Ingeniera"
                },
                {
                  "front": "Doctor",
                  "back": "Doctor/Doctora"
                },
                {
                  "front": "Nurse",
                  "back": "Enfermero/Enfermera"
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex2_work_activities",
            "title": "Actividades Laborales en Presente Continuo",
            "config": {
              "verb": "to work",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Present Continuous"],
              "correct": {
                "I": "am working",
                "You": "are working",
                "He": "is working",
                "We": "are working",
                "They": "are working"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_work_sentences",
            "title": "Describe tu Trabajo",
            "config": {
              "wordBank": [
                "I", "am", "working", "as", "a",
                "teacher", "engineer", "doctor", "nurse",
                "in", "an", "office", "hospital", "school",
                "today", "right", "now", "this", "week"
              ],
              "correctAnswers": [
                "I am working as a teacher",
                "He is working in an office",
                "They are working at the hospital"
              ],
              "requiredWords": ["am", "is", "are"],
              "timeLimit": 110
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_job_interview",
            "title": "Simulación: Entrevista de Trabajo",
            "config": {
              "scenario": "Job interview about work experience",
              "dialogues": [
                {
                  "character": "interviewer",
                  "text": "What are you currently working on?",
                  "options": ["I'm working on a software project", "I'm teaching at a school"]
                },
                {
                  "character": "user",
                  "text": "Where do you see yourself in five years?",
                  "options": ["I'm hoping to be a manager", "I want to continue learning"]
                }
              ]
            }
          }
        ]
      }
    },
    "A2_recent_past": {
      "id": "A2_recent_past",
      "title": "Pasado Reciente",
      "xpReward": 175,
      "metadata": {
        "level": "A2",
        "module": "grammar",
        "unit": "unitA2_recent_past",
        "xpReward": 175,
        "estimatedDuration": 58,
        "tags": ["present_perfect", "past_simple", "recent_past", "time_expressions"]
      },
      "content": {
        "vocabulary": [
          {
            "id": "voc_just_finished",
            "word": "Just finished",
            "translation": "Acabo de terminar",
            "examples": ["I have just finished my work"],
            "tags": ["present_perfect", "recent"]
          },
          {
            "id": "voc_already_seen",
            "word": "Already seen",
            "translation": "Ya he visto",
            "examples": ["I have already seen that movie"],
            "tags": ["present_perfect", "experience"]
          },
          {
            "id": "voc_yesterday_went",
            "word": "Went yesterday",
            "translation": "Fui ayer",
            "examples": ["I went to the store yesterday"],
            "tags": ["past_simple", "specific_time"]
          },
          {
            "id": "voc_last_week",
            "word": "Last week",
            "translation": "La semana pasada",
            "examples": ["We traveled last week"]
          }
        ],
        "exercises": [
          {
            "type": "matching",
            "id": "ex1_time_expressions",
            "title": "Expresiones de Tiempo",
            "config": {
              "pairs": [
                {
                  "from": "Just",
                  "to": "Usado con Present Perfect"
                },
                {
                  "from": "Yesterday",
                  "to": "Usado con Past Simple"
                },
                {
                  "from": "Already",
                  "to": "Usado con Present Perfect"
                },
                {
                  "from": "Last week",
                  "to": "Usado con Past Simple"
                }
              ]
            }
          },
          {
            "type": "drag_drop",
            "id": "ex2_present_vs_past",
            "title": "Present Perfect vs Past Simple",
            "config": {
              "question": "Elige el tiempo verbal correcto",
              "pairs": [
                {
                  "id": "tense1",
                  "from": "I ___ just finished my homework",
                  "to": "have"
                },
                {
                  "id": "tense2",
                  "from": "She ___ to Paris last year",
                  "to": "went"
                },
                {
                  "id": "tense3",
                  "from": "They ___ already seen that movie",
                  "to": "have"
                }
              ]
            }
          },
          {
            "type": "sentence_formation",
            "id": "ex3_recent_actions",
            "title": "Acciones Recientes vs Pasadas",
            "config": {
              "wordBank": [
                "I", "have", "has", "went", "seen",
                "finished", "just", "already", "yesterday",
                "last", "week", "year", "to", "the", "store"
              ],
              "correctAnswers": [
                "I have just finished my work",
                "She went to Paris last year",
                "They have already seen that movie"
              ],
              "requiredWords": ["have", "has", "went"],
              "timeLimit": 130
            }
          },
          {
            "type": "dialogue_simulation",
            "id": "ex4_recent_experiences",
            "title": "Hablando de Experiencias Recientes",
            "config": {
              "scenario": "Talking about recent and past experiences",
              "dialogues": [
                {
                  "character": "friend",
                  "text": "What have you done recently?",
                  "options": ["I've just started a new job", "I already finished my course"]
                },
                {
                  "character": "user",
                  "text": "What did you do last weekend?",
                  "options": ["I went to the beach", "I visited my family"]
                }
              ]
            }
          },
          {
            "type": "conjugation",
            "id": "ex5_verb_tenses",
            "title": "Conjugación: Present Perfect vs Past Simple",
            "config": {
              "verb": "to see",
              "pronouns": ["I", "You", "He", "We"],
              "tenses": ["Present Perfect", "Past Simple"],
              "correct": {
                "Present Perfect": "have seen",
                "Past Simple": "saw"
              },
              "hints": {
                "showBaseForm": true
              }
            }
          }
        ]
      }
    },
    "A2_transportation": {
