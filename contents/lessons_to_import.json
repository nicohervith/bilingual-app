            "tags": ["stative_verbs", "hobbies"]
          },
          {
            "id": "voc_enjoy_watching",
            "word": "Enjoy watching",
            "translation": "Disfruto ver",
            "examples": ["She enjoys watching movies"],
            "tags": ["stative_verbs", "entertainment"]
          },
          {
            "id": "voc_hobby",
            "word": "Hobby",
            "translation": "Pasatiempo",
            "examples": ["My hobby is photography"]
          },
          {
            "id": "voc_leisure",
            "word": "Leisure",
            "translation": "Ocio",
            "examples": ["What do you do in your leisure time?"]
          }
