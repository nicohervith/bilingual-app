          },
          {
            "type": "conjugation",
            "id": "ex2_art_verbs",
            "title": "Verbos Irregulares del Arte",
            "config": {
              "verb": "to draw",
              "pronouns": ["I", "You", "He", "We", "They"],
              "tenses": ["Past Simple"],
              "correct": {
                "I": "drew",
