{
  "expo": {
    "name": "bilingual-app",
    "slug": "bilingual-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bilingualapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.bilingual.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bilingual.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "config": {
        "firebase": {
          "apiKey": "AIzaSyC40iEVDPzMrQBEjPAuYss5lzvhpH_ZrsU",
          "authDomain": "bilingual-site-65404.firebaseapp.com",
          "projectId": "bilingual-site-65404",
          "storageBucket": "bilingual-site-65404.firebasestorage.app",
          "messagingSenderId": "500497750948",
          "appId": "1:500497750948:web:082933a226e1224f5abf31"
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ce23dcc-ddd7-48e3-9dc1-a858cff14640"
      }
    }
  }
}
