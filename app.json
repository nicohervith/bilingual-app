{
  "expo": {
    "name": "bilingual-app",
    "slug": "bilingual-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bilingualapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.bilingual.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bilingual.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "config": {
        "firebase": {
          "apiKey": "AIzaSyBUm57cQI67Joupf4dovElZYeOnmXcpYcs",
          "authDomain": "bilingualsite-ee6f8.firebaseapp.com",
          "projectId": "bilingualsite-ee6f8",
          "storageBucket": "bilingualsite-ee6f8.firebasestorage.app",
          "messagingSenderId": "871050529166",
          "appId": "1:871050529166:web:b1d0a762819fed9be6bcdf"
        }
      }
    },
    "plugins": [

      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ce23dcc-ddd7-48e3-9dc1-a858cff14640"
      }
    }
  }
}
